# KeyShift Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=generate-a-secure-random-key-here
FLASK_ENV=production
FLASK_DEBUG=false

# Database
DATABASE_URL=sqlite:///KeyShift.db

# UniFi/Omada API Configuration
CONTROLLER_IP=192.168.1.1
API_TYPE=unifi
# For UniFi:
UNIFI_API_KEY=your-api-key-here
# For Omada:
OMADA_USERNAME=your-username
OMADA_PASSWORD=your-password

# Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Logging
LOG_LEVEL=INFO

# Optional: SSL Certificate Path (if using self-signed)
SSL_CERT_PATH=/path/to/ca-cert.pem

# Timezone
TZ=America/Chicago
